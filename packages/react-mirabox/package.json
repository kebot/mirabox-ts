{
  "name": "react-mirabox",
  "version": "0.1.0",
  "description": "React + Konva headless key renderer for mirabox devices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=node --external skia-canvas && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun src/index.ts",
    "demo": "bun --watch demo.tsx",
    "postinstall": "node ./node_modules/skia-canvas/lib/prebuild.mjs download --or-compile"
  },
  "dependencies": {
    "mirabox-client": "workspace:*",
    "skia-canvas": "^3.0.8",
    "konva": "^10.2.5",
    "react": "^19.2.4",
    "react-konva": "^19.2.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
